# Copy to .env.local and fill in from your Supabase project (Settings -> API).
# Vite only exposes variables prefixed with VITE_ to the browser.
# The anon key is safe in the browser — Row-Level Security gates all data.
# Never put the service_role key in a VITE_ var or commit it anywhere.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Used ONLY by scripts/seed-demo-users.mjs (Node, never shipped to browser) ──
# Settings -> API -> service_role secret. Keep it out of .env.local if you can;
# prefer passing it inline: SUPABASE_SERVICE_ROLE_KEY=... npm run seed:users
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret
